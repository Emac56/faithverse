# .gitignore
# Files and folders that Git should NOT track or upload.

# Environment variables (contains passwords!)
.env

# Python virtual environment (very large, not needed on GitHub)
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Database files
*.db
*.sqlite
cookies.txt

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
